{
  "name": "@wms/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local --import=tsx --watch src/index.ts",
    "lint": "eslint src test --max-warnings=0",
    "start": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wms/db": "workspace:*",
    "@wms/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "zod": "^4.3.6"
  }
}
