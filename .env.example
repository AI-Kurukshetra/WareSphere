NEXT_PUBLIC_APP_NAME=AIMaha Kruksetra WMS
API_BASE_URL=http://localhost:4000
# Optional fallback for local-only setups. Prefer API_BASE_URL for server-side use.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WMS_STORAGE=db

# Runtime connection used by the API. Use a session-pool or direct Postgres URL.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@[POOLER-HOST]:5432/postgres?sslmode=require

# Direct connection used for schema pushes and migrations.
DATABASE_MIGRATION_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Hosted Supabase project settings.
SUPABASE_PROJECT_REF=[PROJECT-REF]
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]
# Required for HS256 token verification. Optional when the project uses ES256/JWKS.
SUPABASE_JWT_SECRET=[JWT-SECRET]
SUPABASE_DB_PASSWORD=[DB-PASSWORD]
SUPABASE_ACCESS_TOKEN=[PERSONAL-ACCESS-TOKEN]

# Enable only for local API testing without real user sessions.
ALLOW_DEV_AUTH_HEADERS=false

REDIS_URL=redis://127.0.0.1:6379
SHOPIFY_APP_URL=https://example-shopify-app.test
WOOCOMMERCE_WEBHOOK_SECRET=[WEBHOOK-SECRET]
